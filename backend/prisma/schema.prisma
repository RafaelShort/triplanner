generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ownedTrips        Trip[]          @relation("TripOwner")
  memberships       TripMember[]
  invitationsSent   Invitation[]    @relation("InvitationSender")
  activitiesCreated Activity[]
  expensesPaid      Expense[]
  expenseSplits     ExpenseSplit[]
  checklistItems    ChecklistItem[]
  comments          Comment[]       

  @@map("users")
}

model Trip {
  id          String    @id @default(uuid())
  name        String
  description String?
  destination String?
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  coverImage  String?   @map("cover_image")
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  owner       User            @relation("TripOwner", fields: [createdBy], references: [id])
  members     TripMember[]
  invitations Invitation[]
  days        Day[]
  activities  Activity[]
  expenses    Expense[]
  checklist   ChecklistItem[]

  @@map("trips")
}

model TripMember {
  id       String   @id @default(uuid())
  tripId   String   @map("trip_id")
  userId   String   @map("user_id")
  role     Role     @default(EDITOR)
  joinedAt DateTime @default(now()) @map("joined_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@map("trip_members")
}

enum Role {
  OWNER
  EDITOR
  VIEWER
}

model Invitation {
  id        String           @id @default(uuid())
  tripId    String           @map("trip_id")
  email     String
  token     String           @unique
  status    InvitationStatus @default(PENDING)
  invitedBy String           @map("invited_by")
  expiresAt DateTime         @map("expires_at")
  createdAt DateTime         @default(now()) @map("created_at")

  trip    Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  inviter User @relation("InvitationSender", fields: [invitedBy], references: [id])

  @@map("invitations")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

model Day {
  id        String   @id @default(uuid())
  tripId    String   @map("trip_id")
  date      DateTime
  title     String?
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@map("days")
}

model Activity {
  id           String       @id @default(uuid())
  dayId        String?      @map("day_id")
  tripId       String       @map("trip_id")
  title        String
  description  String?
  type         ActivityType @default(ACTIVITY)
  locationName String?      @map("location_name")
  latitude     Float?
  longitude    Float?
  startTime    String?      @map("start_time")
  endTime      String?      @map("end_time")
  cost         Float?
  order        Int          @default(0)
  createdBy    String       @map("created_by")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  day      Day?      @relation(fields: [dayId], references: [id], onDelete: SetNull)
  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  creator  User      @relation(fields: [createdBy], references: [id])
  comments Comment[] // ← novo

  @@map("activities")
}

enum ActivityType {
  ACTIVITY
  RESTAURANT
  ACCOMMODATION
  TRANSPORT
  OTHER
}

model Expense {
  id        String   @id @default(uuid())
  tripId    String   @map("trip_id")
  title     String
  amount    Float
  paidBy    String   @map("paid_by")
  category  String?
  date      DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  trip   Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  payer  User           @relation(fields: [paidBy], references: [id])
  splits ExpenseSplit[]

  @@map("expenses")
}

model ExpenseSplit {
  id        String  @id @default(uuid())
  expenseId String  @map("expense_id")
  userId    String  @map("user_id")
  amount    Float
  paid      Boolean @default(false)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@map("expense_splits")
}

model ChecklistItem {
  id        String   @id @default(uuid())
  tripId    String   @map("trip_id")
  createdBy String   @map("created_by")
  text      String
  checked   Boolean  @default(false)
  category  String   @default("GENERAL")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [createdBy], references: [id])

  @@map("checklist_items")
}

model Comment {
  id         String   @id @default(cuid())
  content    String
  activityId String   @map("activity_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@map("comments")
}
